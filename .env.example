# NexusOps Environment Configuration
# Copy to .env and fill in values

# Database
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=nexusops
DATABASE_USER=nexusops
DATABASE_PASSWORD=change-me-in-production

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Authentication
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
JWT_SECRET=change-me-to-a-random-64-char-string

# TLS
TLS_EMAIL=admin@yourdomain.com

# Notifications (optional)
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Runner
RUNNER_MAX_CONCURRENT=5
